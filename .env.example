# ===== 모델 provider =====
AI_PROVIDER=openai            # openai | anthropic (기본 openai)
OPENAI_MODEL=gpt-5.4          # 실제 사용 가능한 모델명으로 조정
OPENAI_API_KEY=sk-...
# 특정 에이전트만 Claude로 돌리려면:
# AGENT_MODELS={"fund-benchmark":"anthropic"}
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ===== Firebase Admin (서버, 커밋 금지) =====
FIREBASE_PROJECT_ID=your-project
FIREBASE_CLIENT_EMAIL=xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ===== Firebase 클라이언트 (브라우저 공개값) =====
NEXT_PUBLIC_FIREBASE_API_KEY=...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_APP_ID=1:...:web:...
